{
  "name": "site",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync && husky",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "oxfmt --check . && oxlint . --ignore-path .gitignore",
    "lint:fix": "oxfmt . && oxlint . --fix --ignore-path .gitignore",
    "ci": "pnpm run lint && pnpm run check && pnpm run build",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-static": "3.0.10",
    "@sveltejs/kit": "2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@types/node": "^25.6.2",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "mdsvex": "^0.12.7",
    "oxfmt": "^0.48.0",
    "oxlint": "^1.63.0",
    "postcss": "^8.5.14",
    "prism-themes": "^1.9.0",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.2.4",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.11"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,cjs,mjs,svelte}": [
      "bash -c 'pnpm run check'",
      "oxfmt",
      "oxlint --fix --ignore-path .gitignore"
    ]
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.0.8"
}
